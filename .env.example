# ─────────────────────────────────────────
# PostgreSQL — Railway provides this on deploy
# ─────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/mysummits"

# ─────────────────────────────────────────
# NextAuth.js v5
# Generate secret with: openssl rand -base64 32
# ─────────────────────────────────────────
AUTH_SECRET="replace-with-generated-secret"

# ─────────────────────────────────────────
# Cloudflare R2 — added in Phase 4
# ─────────────────────────────────────────
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""
