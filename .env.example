# ─────────────────────────────────────────
# PostgreSQL — Railway provides this on deploy
# ─────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/mysummits"

# ─────────────────────────────────────────
# NextAuth.js v5
# Generate secret with: openssl rand -base64 32
# ─────────────────────────────────────────
AUTH_SECRET="replace-with-generated-secret"

# ─────────────────────────────────────────
# Cloudflare R2 — added in Phase 4
# ─────────────────────────────────────────
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""

# ─────────────────────────────────────────
# Admin usage dashboard (optional)
# Cloudflare: create API Token with "Account Analytics:Read" at dash.cloudflare.com/profile/api-tokens
# Railway: create token at railway.app → Account Settings → Tokens
# ─────────────────────────────────────────
CLOUDFLARE_API_TOKEN=""
RAILWAY_TOKEN=""
RAILWAY_PROJECT_ID=""   # Find it in the Railway dashboard URL: railway.app/project/{ID}
