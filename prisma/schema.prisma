// MySummitsPhotoMap — Prisma Schema
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────
// GLOBAL — shared catalog, never duplicated per tenant
// ─────────────────────────────────────────────────────────

/// Fixed rarity catalog — seeded once, never translated.
/// ep is null for Mythic (computed at runtime from altitude tier).
/// crains is a bonus on top of ep (only Mythic uses it currently).
model Rarity {
  id     String @id  // "daisy" | "lavender" | "gentian" | "edelweiss" | "saxifrage" | "mythic"
  name   String
  emoji  String
  order  Int         // display sort order 1–6
  ep     Int?        // elevation points awarded — null = computed at runtime
  crains Int         @default(0)  // cairns bonus points

  peaks Peak[]

  @@map("rarities")
}

model Peak {
  id            String   @id @default(uuid())
  name          String
  nameEn        String?
  comarca       String?
  latitude      Float
  longitude     Float
  altitudeM     Int
  mountainRange String?
  tag1          String?
  tag2          String?
  tag3          String?
  country       String   @default("ES")
  gpsVerified   Boolean  @default(false)
  isMythic          Boolean  @default(false)
  rarityId          String?
  elevationProfile  Json?
  createdAt         DateTime @default(now())

  osmId     String?        @unique

  rarity    Rarity?        @relation(fields: [rarityId], references: [id])
  ascents   Ascent[]
  wikiTexts PeakWikiText[]

  @@index([rarityId])
  @@index([country])
  @@index([altitudeM])
  @@index([latitude, longitude])
  @@map("peaks")
}

model PeakWikiText {
  id         String   @id @default(uuid())
  peakId     String
  lang       String
  title      String
  body       String
  wikiUrl    String
  confidence Float
  status     String
  fetchedAt  DateTime @default(now())

  peak Peak @relation(fields: [peakId], references: [id], onDelete: Cascade)

  @@unique([peakId, lang])
  @@index([peakId])
  @@map("peak_wiki_descriptions")
}

// ─────────────────────────────────────────────────────────
// CONTROL PLANE — auth & tenant orchestration (no tenant_id)
// ─────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  emailVerified DateTime?
  passwordHash  String?
  name         String
  username     String?  @unique
  bio          String?
  language     String   @default("en")

  // Privacy
  appearInSearch        Boolean @default(true)
  allowOthersToTag      Boolean @default(true)

  // Notifications
  emailNotifications    Boolean @default(true)
  activityNotifications Boolean @default(true)

  // Photos & Tagging
  autoDetectFaces       Boolean @default(true)
  autoSuggestPeople     Boolean @default(true)
  reviewFacesBeforeSave Boolean @default(false)

  // Avatar
  avatarUrl    String?

  // Onboarding
  mapOnboardingSeen Boolean @default(false)

  // System
  isAdmin      Boolean  @default(false)

  // Legal consent
  marketingConsent   Boolean   @default(false)
  marketingConsentAt DateTime?

  createdAt    DateTime @default(now())

  memberships            Membership[]
  ascents                Ascent[]
  sentFriendRequests     Friendship[] @relation("SentFriendRequests")
  receivedFriendRequests Friendship[] @relation("ReceivedFriendRequests")
  faceTags               FaceTag[]    @relation("FaceTagUser")
  feedSeens              FeedSeen[]
  accounts               Account[]
  legalConsents          LegalConsent[]
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  /// null = shared DB (current); non-null = dedicated DB URL (future per-tenant isolation)
  dbUrl     String?
  createdAt DateTime @default(now())

  memberships    Membership[]
  ascents        Ascent[]
  photos         Photo[]
  faceDetections FaceDetection[]
  faceTags       FaceTag[]

  @@map("tenants")
}

model Membership {
  id        String         @id @default(uuid())
  userId    String
  tenantId  String
  role      MembershipRole @default(OWNER)
  createdAt DateTime       @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@index([userId])
  @@index([tenantId])
  @@map("memberships")
}

enum MembershipRole {
  OWNER
  ADMIN
  MEMBER
}


model PasswordResetToken {
  id        String    @id @default(uuid())
  email     String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email])
  @@map("password_reset_tokens")
}

model Friendship {
  id          String           @id @default(uuid())
  requesterId String
  addresseeId String
  status      FriendshipStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  requester User @relation("SentFriendRequests",     fields: [requesterId], references: [id], onDelete: Cascade)
  addressee User @relation("ReceivedFriendRequests", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@unique([requesterId, addresseeId])
  @@index([addresseeId, status])
  @@index([requesterId, status])
  @@map("friendships")
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  REJECTED
  BLOCKED
}

// ─────────────────────────────────────────────────────────
// DATA PLANE — all tables are tenant-scoped (tenantId required)
// ─────────────────────────────────────────────────────────

model Ascent {
  id          String   @id @default(uuid())
  tenantId    String
  peakId      String
  date        DateTime @db.Date
  route       String?
  description String?
  wikiloc     String?   // embed src URL, e.g. https://es.wikiloc.com/wikiloc/embedv2.do?id=...
  isPublic    Boolean  @default(false)  // true = shareable via public link
  createdBy   String
  createdAt   DateTime @default(now())

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  peak      Peak       @relation(fields: [peakId], references: [id])
  user      User       @relation(fields: [createdBy], references: [id])
  photos    Photo[]
  feedSeens FeedSeen[]

  @@index([tenantId])
  @@index([tenantId, peakId])
  @@index([createdBy])
  @@index([createdBy, date])
  @@map("ascents")
}

model Photo {
  id         String   @id @default(uuid())
  tenantId   String
  ascentId   String
  /// S3/R2 object key — e.g. tenant/{tenantId}/photos/{photoId}.jpg
  storageKey String
  /// Public CDN URL
  url        String
  createdAt  DateTime @default(now())

  /// S3/R2 object key for the resized original — e.g. tenant/{tenantId}/photos/{photoId}_original.jpg
  /// null = legacy photo (original not available)
  originalStorageKey String?
  /// Crop region as fractions [0-1] of the original image dimensions
  cropX      Float?
  cropY      Float?
  cropW      Float?
  cropH      Float?
  /// Aspect ratio of the crop — e.g. "4:5" or "1:1"
  cropAspect    String?
  /// Clockwise rotation applied before cropping — 0, 90, 180 or 270
  cropRotation  Int?

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ascent         Ascent          @relation(fields: [ascentId], references: [id], onDelete: Cascade)
  faceDetections FaceDetection[]

  @@index([tenantId, ascentId])
  @@map("photos")
}

model FaceDetection {
  id          String   @id @default(uuid())
  tenantId    String
  photoId     String
  /// { x: number, y: number, width: number, height: number }
  boundingBox Json
  /// 128-float face descriptor vector, stored as number[]
  descriptor  Json?
  createdAt   DateTime @default(now())

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  photo    Photo     @relation(fields: [photoId], references: [id], onDelete: Cascade)
  faceTags FaceTag[]

  @@index([tenantId, photoId])
  @@map("face_detections")
}

model FaceTag {
  id              String    @id @default(uuid())
  tenantId        String
  faceDetectionId String
  userId          String?
  status          TagStatus @default(ACCEPTED)
  createdAt       DateTime  @default(now())

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  faceDetection FaceDetection  @relation(fields: [faceDetectionId], references: [id], onDelete: Cascade)
  user          User?          @relation("FaceTagUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([faceDetectionId, userId])
  @@index([tenantId, userId])
  @@index([tenantId, status])
  @@map("face_tags")
}

enum TagStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model FeedSeen {
  userId   String
  ascentId String
  seenAt   DateTime @default(now())

  user   User   @relation(fields: [userId],   references: [id], onDelete: Cascade)
  ascent Ascent @relation(fields: [ascentId], references: [id], onDelete: Cascade)

  @@id([userId, ascentId])
  @@index([userId, seenAt])
  @@map("feed_seen")
}

model NewsletterSubscriber {
  id        String   @id @default(uuid())
  email     String   @unique
  locale    String   @default("es")  // landing locale at signup time
  createdAt DateTime @default(now())

  @@map("newsletter_subscribers")
}

// ── Legal consent audit trail ─────────────────────────────────────────────────
// One row per (user, documentType, version) — never updated, only inserted.
// Keeps a full history: user accepted terms v1.0 on X, then v1.1 on Y, etc.
model LegalConsent {
  id           String   @id @default(uuid())
  userId       String
  documentType String   // "terms" | "privacy"
  version      String   // e.g. "1.0", "1.1"
  acceptedAt   DateTime @default(now())
  ipAddress    String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, documentType, version])
  @@index([userId])
  @@map("legal_consents")
}

