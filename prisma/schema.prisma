// MySummitsPhotoMap — Prisma Schema
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────
// GLOBAL — shared catalog, never duplicated per tenant
// ─────────────────────────────────────────────────────────

/// Fixed rarity catalog — seeded once, never translated.
/// ep is null for Mythic (computed at runtime from altitude tier).
/// crains is a bonus on top of ep (only Mythic uses it currently).
model Rarity {
  id     String @id  // "daisy" | "lavender" | "gentian" | "edelweiss" | "saxifrage" | "mythic"
  name   String
  emoji  String
  order  Int         // display sort order 1–6
  ep     Int?        // elevation points awarded — null = computed at runtime
  crains Int         @default(0)  // cairns bonus points

  peaks Peak[]

  @@map("rarities")
}

model Peak {
  id            String   @id @default(uuid())
  name          String
  comarca       String?
  latitude      Float
  longitude     Float
  altitudeM     Int
  mountainRange String?
  tag1          String?
  tag2          String?
  tag3          String?
  country       String   @default("ES")
  gpsVerified   Boolean  @default(false)
  isMythic      Boolean  @default(false)
  rarityId      String?
  createdAt     DateTime @default(now())

  rarity  Rarity? @relation(fields: [rarityId], references: [id])
  ascents Ascent[]

  @@index([rarityId])
  @@map("peaks")
}

// ─────────────────────────────────────────────────────────
// CONTROL PLANE — auth & tenant orchestration (no tenant_id)
// ─────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  username     String?  @unique
  bio          String?
  language     String   @default("en")

  // Privacy
  appearInSearch        Boolean @default(true)
  allowOthersToTag      Boolean @default(true)

  // Notifications
  emailNotifications    Boolean @default(true)
  activityNotifications Boolean @default(true)

  // Photos & Tagging
  autoDetectFaces       Boolean @default(true)
  autoSuggestPeople     Boolean @default(true)
  reviewFacesBeforeSave Boolean @default(false)

  // Avatar
  avatarUrl    String?

  // System
  isAdmin      Boolean  @default(false)

  // Registration — voucher used to sign up (null for pre-voucher users)
  voucherId    String?

  createdAt    DateTime @default(now())

  memberships            Membership[]
  ascents                Ascent[]
  sentFriendRequests     Friendship[] @relation("SentFriendRequests")
  receivedFriendRequests Friendship[] @relation("ReceivedFriendRequests")
  faceTags               FaceTag[]    @relation("FaceTagUser")
  sentInvitations        Voucher[]    @relation("SentInvitations")
  voucherUse             VoucherUse?

  @@map("users")
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  /// null = shared DB (current); non-null = dedicated DB URL (future per-tenant isolation)
  dbUrl     String?
  createdAt DateTime @default(now())

  memberships    Membership[]
  ascents        Ascent[]
  photos         Photo[]
  faceDetections FaceDetection[]
  faceTags       FaceTag[]

  @@map("tenants")
}

model Membership {
  id        String         @id @default(uuid())
  userId    String
  tenantId  String
  role      MembershipRole @default(OWNER)
  createdAt DateTime       @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@index([userId])
  @@index([tenantId])
  @@map("memberships")
}

enum MembershipRole {
  OWNER
  ADMIN
  MEMBER
}

model Voucher {
  id           String    @id @default(uuid())
  code         String    @unique
  maxUses      Int       @default(1)
  usedCount    Int       @default(0)
  note         String?
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())
  // Invitation fields — null for admin-created vouchers
  inviterId    String?
  inviteeEmail String?

  uses    VoucherUse[]
  inviter User?        @relation("SentInvitations", fields: [inviterId], references: [id], onDelete: SetNull)

  @@index([inviterId])
  @@map("vouchers")
}

model VoucherUse {
  id        String   @id @default(uuid())
  voucherId String
  userId    String
  usedAt    DateTime @default(now())

  voucher Voucher @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])
  @@index([voucherId])
  @@map("voucher_uses")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  email     String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email])
  @@map("password_reset_tokens")
}

model Friendship {
  id          String           @id @default(uuid())
  requesterId String
  addresseeId String
  status      FriendshipStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  requester User @relation("SentFriendRequests",     fields: [requesterId], references: [id], onDelete: Cascade)
  addressee User @relation("ReceivedFriendRequests", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@unique([requesterId, addresseeId])
  @@index([addresseeId, status])
  @@index([requesterId, status])
  @@map("friendships")
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  REJECTED
  BLOCKED
}

// ─────────────────────────────────────────────────────────
// DATA PLANE — all tables are tenant-scoped (tenantId required)
// ─────────────────────────────────────────────────────────

model Ascent {
  id          String   @id @default(uuid())
  tenantId    String
  peakId      String
  date        DateTime @db.Date
  route       String?
  description String?
  wikiloc     String?   // embed src URL, e.g. https://es.wikiloc.com/wikiloc/embedv2.do?id=...
  createdBy   String
  createdAt   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  peak   Peak   @relation(fields: [peakId], references: [id])
  user   User   @relation(fields: [createdBy], references: [id])
  photos Photo[]

  @@index([tenantId])
  @@index([tenantId, peakId])
  @@map("ascents")
}

model Photo {
  id         String   @id @default(uuid())
  tenantId   String
  ascentId   String
  /// S3/R2 object key — e.g. tenant/{tenantId}/photos/{photoId}.jpg
  storageKey String
  /// Public CDN URL
  url        String
  createdAt  DateTime @default(now())

  /// S3/R2 object key for the resized original — e.g. tenant/{tenantId}/photos/{photoId}_original.jpg
  /// null = legacy photo (original not available)
  originalStorageKey String?
  /// Crop region as fractions [0-1] of the original image dimensions
  cropX      Float?
  cropY      Float?
  cropW      Float?
  cropH      Float?
  /// Aspect ratio of the crop — e.g. "4:5" or "1:1"
  cropAspect    String?
  /// Clockwise rotation applied before cropping — 0, 90, 180 or 270
  cropRotation  Int?

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ascent         Ascent          @relation(fields: [ascentId], references: [id], onDelete: Cascade)
  faceDetections FaceDetection[]

  @@index([tenantId, ascentId])
  @@map("photos")
}

model FaceDetection {
  id          String   @id @default(uuid())
  tenantId    String
  photoId     String
  /// { x: number, y: number, width: number, height: number }
  boundingBox Json
  /// 128-float face descriptor vector, stored as number[]
  descriptor  Json?
  createdAt   DateTime @default(now())

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  photo    Photo     @relation(fields: [photoId], references: [id], onDelete: Cascade)
  faceTags FaceTag[]

  @@index([tenantId, photoId])
  @@map("face_detections")
}

model FaceTag {
  id              String    @id @default(uuid())
  tenantId        String
  faceDetectionId String
  userId          String?
  status          TagStatus @default(ACCEPTED)
  createdAt       DateTime  @default(now())

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  faceDetection FaceDetection  @relation(fields: [faceDetectionId], references: [id], onDelete: Cascade)
  user          User?          @relation("FaceTagUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([faceDetectionId, userId])
  @@index([tenantId, userId])
  @@index([tenantId, status])
  @@map("face_tags")
}

enum TagStatus {
  PENDING
  ACCEPTED
  REJECTED
}
