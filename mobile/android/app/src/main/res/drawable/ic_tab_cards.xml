<?xml version="1.0" encoding="utf-8"?>
<!-- Cards tab icon: two portrait cards with rounded corners, back card tilted -18° -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Back card: rotated -18° around its centre (9,10), slate-400 fill -->
    <!-- Rounded rect M4,3→14,17 r=2: top-left arc, top edge, top-right arc,
         right edge, bottom-right arc, bottom edge, bottom-left arc, left edge -->
    <group
        android:rotation="-18"
        android:pivotX="9"
        android:pivotY="10">
        <path
            android:pathData="M6,3 L12,3 Q14,3 14,5 L14,15 Q14,17 12,17 L6,17 Q4,17 4,15 L4,5 Q4,3 6,3 Z"
            android:fillColor="#94A3B8"
            android:strokeColor="#64748B"
            android:strokeWidth="1.2"
            android:strokeLineJoin="round" />
    </group>

    <!-- Front card: upright, rounded rect M9,5→20,21 r=2 -->
    <path
        android:pathData="M11,5 L18,5 Q20,5 20,7 L20,19 Q20,21 18,21 L11,21 Q9,21 9,19 L9,7 Q9,5 11,5 Z"
        android:fillColor="#FFFFFF"
        android:strokeColor="#1E293B"
        android:strokeWidth="1.7"
        android:strokeLineJoin="round" />

    <!-- Front card header divider -->
    <path
        android:pathData="M10.5,9.5 L18.5,9.5"
        android:fillColor="#00000000"
        android:strokeColor="#1E293B"
        android:strokeWidth="1.3"
        android:strokeLineCap="round" />

    <!-- Mountain silhouette in front card body -->
    <path
        android:pathData="M10.5,19 L13.2,15 L15.2,16.8 L16.7,14.5 L19,19 Z"
        android:fillColor="#64748B"
        android:strokeColor="#00000000" />

</vector>
