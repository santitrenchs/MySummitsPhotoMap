<?xml version="1.0" encoding="utf-8"?>
<!-- Cards tab icon: two portrait cards, back card tilted -14° -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Back card: tilted -14°, slate fill — peeks left + top of front card -->
    <group
        android:rotation="-14"
        android:pivotX="10"
        android:pivotY="11">
        <path
            android:pathData="M5,4 L15,4 L15,18 L5,18 Z"
            android:fillColor="#CBD5E1"
            android:strokeColor="#94A3B8"
            android:strokeWidth="1.5"
            android:strokeLineJoin="round" />
    </group>

    <!-- Front card: upright, white fill with navy outline -->
    <path
        android:pathData="M8,5 L19,5 L19,20 L8,20 Z"
        android:fillColor="#FFFFFF"
        android:strokeColor="#0F2233"
        android:strokeWidth="1.8"
        android:strokeLineJoin="round" />

    <!-- Front card header divider -->
    <path
        android:pathData="M9.5,9 L17.5,9"
        android:fillColor="#00000000"
        android:strokeColor="#0F2233"
        android:strokeWidth="1.4"
        android:strokeLineCap="round" />

    <!-- Mountain silhouette in front card body -->
    <path
        android:pathData="M9.5,18.5 L12,14.5 L14,16.5 L15.5,14 L18,18.5 Z"
        android:fillColor="#64748B"
        android:strokeColor="#00000000" />

</vector>
