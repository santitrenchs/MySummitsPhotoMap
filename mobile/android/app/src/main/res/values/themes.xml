<resources>
    <!-- Base app theme — AppCompat parent required for AppCompatDelegate locale switching.
         Actual theming (colors, typography) is done entirely in Compose via PeakadexTheme. -->
    <style name="Theme.Peakadex" parent="Theme.AppCompat.Light.NoActionBar" />

    <!-- Splash screen theme (androidx.core:core-splashscreen)
         White background + Peakadex logo centred — matches SplashScreen.kt for a
         seamless system-splash → app-splash transition. -->
    <style name="Theme.Peakadex.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#FFFFFF</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.Peakadex</item>
    </style>
</resources>
