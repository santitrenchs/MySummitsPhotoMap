{
  "name": "my-summits-photo-map",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint app components lib",
    "typecheck": "tsc --noEmit",
    "check:i18n": "node scripts/check-i18n.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:reveal": "playwright test --config=playwright.reveal.config.ts",
    "db:generate": "prisma generate",
    "db:push": "dotenv -e .env.local -- prisma db push",
    "db:migrate": "dotenv -e .env.local -- prisma migrate dev",
    "db:studio": "dotenv -e .env.local -- prisma studio",
    "db:seed": "dotenv -e .env.local -- tsx prisma/seed.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@aws-sdk/client-s3": "^3.696.0",
    "@aws-sdk/s3-request-presigner": "^3.696.0",
    "@prisma/client": "^5.22.0",
    "@vladmandic/face-api": "^1.7.15",
    "autoprefixer": "^10.4.27",
    "bcryptjs": "^2.4.3",
    "exifr": "^7.1.3",
    "lottie-colorify": "^0.8.0",
    "lottie-react": "^2.4.1",
    "maplibre-gl": "^4.7.1",
    "next": "^16.2.3",
    "next-auth": "^5.0.0-beta.25",
    "opentype.js": "^2.0.0",
    "react": "^18",
    "react-dom": "^18",
    "react-virtuoso": "^4.18.7",
    "resend": "^6.11.0",
    "sharp": "^0.34.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.59.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/opentype.js": "^1.3.9",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitest/coverage-v8": "^4.1.5",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.3",
    "postcss": "^8",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.19.1",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
